@startuml Zoiro Broast Hub - Class Diagram

!define PRIMARY_COLOR #4A90E2
!define SECONDARY_COLOR #50C878
!define DATABASE_COLOR #FFB84D
!define API_COLOR #E67E22

skinparam class {
    BackgroundColor WHITE
    BorderColor BLACK
    ArrowColor BLACK
}

' ==================== FRONTEND COMPONENTS ====================

package "Frontend Layer" <<Rectangle>> {
    
    class AuthComponents {
        +LoginForm
        +RegisterForm
        +OTPVerification
        +TwoFactorDialog
        +PasswordResetForm
        --
        +handleLogin()
        +handleRegister()
        +verifyOTP()
        +enable2FA()
    }
    
    class PortalComponents {
        +Dashboard
        +OrdersPage
        +KitchenPage
        +BillingPage
        +DeliveryPage
        +MenuPage
        +EmployeesPage
        +CustomersPage
        +InventoryPage
        +AttendancePage
        +PayrollPage
        +ReportsPage
        +PerksPage
        +ReviewsPage
        +DealsPage
        +NotificationsPage
        +SettingsPage
        --
        +renderContent()
        +handleRefresh()
    }
    
    class CustomerComponents {
        +MenuBrowser
        +CartComponent
        +CheckoutPage
        +OrderTracking
        +ProfilePage
        +FavoritesPage
        +LoyaltyPage
        +ReviewSubmission
        --
        +addToCart()
        +placeOrder()
        +trackOrder()
        +earnPoints()
    }
    
    class ContextProviders {
        +AuthContext
        +PortalContext
        +CartContext
        +FavoritesContext
        --
        +provideUserState()
        +provideCartState()
        +syncFavorites()
    }
}

' ==================== BUSINESS LOGIC / HOOKS ====================

package "Business Logic Layer" <<Rectangle>> {
    
    class AuthHooks {
        +useAuth()
        +usePortal()
        +getCurrentUser()
        +logout()
        --
        -validateToken()
        -refreshSession()
    }
    
    class DataHooks {
        +useQuery()
        +useMutation()
        +useRealtime()
        +useCache()
        --
        +fetchData()
        +invalidateCache()
    }
    
    class RealtimeManager {
        -channels: Map
        -subscriptions: Set
        --
        +subscribe(channel)
        +unsubscribe(channel)
        +deduplicateChannels()
        +handleRealtimeUpdate()
    }
}

' ==================== API / SERVER LAYER ====================

package "API Layer (Next.js Routes)" <<API_COLOR>> {
    
    class AuthAPI {
        +POST /api/auth/login
        +POST /api/auth/register
        +POST /api/auth/logout
        +POST /api/auth/verify-otp
        +POST /api/portal/security/2fa
        --
        -generateOTP()
        -sendEmail()
        -createJWT()
        -validateRateLimit()
    }
    
    class OrderAPI {
        +POST /api/orders/create
        +GET /api/orders/track
        +PUT /api/orders/update-status
        +POST /api/orders/cancel
        --
        -createOrderRPC()
        -calculateTotal()
        -applyPromoCode()
        -sendConfirmation()
    }
    
    class AdminAPI {
        +GET /api/admin/employees
        +POST /api/admin/employees
        +PUT /api/admin/employees
        +DELETE /api/admin/employees
        +GET /api/admin/menu-items
        +POST /api/admin/menu-items
        +PUT /api/admin/menu-items
        +DELETE /api/admin/menu-items
        +POST /api/upload/image
        --
        -validatePermissions()
        -imageUpload()
        -invalidateCache()
    }
    
    class PayrollAPI {
        +GET /api/admin/payroll
        +POST /api/admin/payroll/generate
        +GET /api/admin/attendance
        +POST /api/admin/attendance/clock-in
        +POST /api/admin/attendance/clock-out
        --
        -calculateHours()
        -generatePDF()
        -emailPayslip()
    }
}

' ==================== LIBRARY / UTILITIES ====================

package "Utilities & Services" <<Rectangle>> {
    
    class AuthService {
        +jwt.ts
        +cookies.ts
        +permissions.ts
        --
        +generateToken()
        +validateToken()
        +setSecureCookie()
        +checkPermission()
    }
    
    class CacheService {
        +cache.ts (Redis)
        +request-dedup.ts
        --
        +get(key)
        +set(key, value, ttl)
        +invalidate(pattern)
        +deduplicate(request)
    }
    
    class EmailService {
        +brevo.ts
        --
        +sendOTP()
        +sendWelcome()
        +sendOrderConfirmation()
        +sendPasswordReset()
        +sendEmployeeActivation()
    }
    
    class StorageService {
        +storage.ts
        --
        +uploadImage()
        +deleteImage()
        +getPublicURL()
    }
    
    class RateLimitService {
        +rate-limit.ts
        --
        +checkLimit(ip, endpoint)
        +incrementCounter()
        +resetCounter()
    }
    
    class PayrollPDFService {
        +payroll-pdf.ts
        --
        +generatePayslip()
        +addBranding()
        +calculateTotals()
    }
}

' ==================== DATABASE LAYER ====================

package "Database Layer (Supabase)" <<DATABASE_COLOR>> {
    
    class SupabaseClient {
        +supabase.ts
        --
        +createClient()
        +query()
        +realtime()
    }
    
    class ServerQueries {
        +server-queries.ts
        +portal-queries.ts
        +customer-queries.ts
        +inventory-queries.ts
        --
        +getDashboardData()
        +getOrders()
        +getEmployees()
        +getMenuItems()
    }
    
    class RPCFunctions {
        +create-order-rpc.sql
        +create-employee-complete-rpc.sql
        +attendance-rpc.sql
        +billing-rpc.sql
        +apply-promo-code-rpc.sql
        +customer-management-rpc.sql
        --
        +executeRPC()
    }
}

' ==================== DATABASE TABLES ====================

package "Database Tables" <<DATABASE_COLOR>> {
    
    entity Employees {
        * id: uuid
        --
        email: string
        name: string
        role: enum
        is_2fa_enabled: boolean
        two_fa_secret: text
        is_blocked: boolean
        created_at: timestamp
    }
    
    entity Customers {
        * id: uuid
        --
        email: string
        name: string
        phone: string
        loyalty_points: integer
        is_2fa_enabled: boolean
        created_at: timestamp
    }
    
    entity Orders {
        * id: uuid (auto-generated)
        --
        customer_id: uuid
        status: enum
        total_amount: decimal
        promo_code: string
        delivery_type: enum
        created_at: timestamp
    }
    
    entity OrderItems {
        * id: uuid
        --
        order_id: uuid
        menu_item_id: uuid
        quantity: integer
        price: decimal
    }
    
    entity MenuItems {
        * id: uuid
        --
        name: string
        category_id: uuid
        price: decimal
        image_url: text
        is_available: boolean
        description: text
    }
    
    entity Categories {
        * id: uuid
        --
        name: string
        description: text
        display_order: integer
    }
    
    entity Inventory {
        * id: uuid
        --
        item_name: string
        quantity: integer
        unit: string
        low_stock_threshold: integer
        last_updated: timestamp
    }
    
    entity Attendance {
        * id: uuid
        --
        employee_id: uuid
        clock_in: timestamp
        clock_out: timestamp
        hours_worked: decimal
        date: date
    }
    
    entity Payroll {
        * id: uuid
        --
        employee_id: uuid
        period_start: date
        period_end: date
        hours_worked: decimal
        gross_pay: decimal
        net_pay: decimal
        status: enum
    }
    
    entity PromoCodes {
        * id: uuid
        --
        code: string
        discount_type: enum
        discount_value: decimal
        expiry_date: date
        usage_limit: integer
        customer_id: uuid (nullable)
    }
    
    entity Reviews {
        * id: uuid
        --
        customer_id: uuid
        order_id: uuid
        rating: integer
        comment: text
        is_approved: boolean
        created_at: timestamp
    }
    
    entity Notifications {
        * id: uuid
        --
        user_id: uuid
        type: enum
        message: text
        is_read: boolean
        created_at: timestamp
    }
    
    entity Tables {
        * id: uuid
        --
        table_number: integer
        capacity: integer
        status: enum
        assigned_waiter: uuid
    }
}

' ==================== RELATIONSHIPS ====================

' Frontend to Business Logic
AuthComponents --> AuthHooks : uses
PortalComponents --> DataHooks : uses
CustomerComponents --> DataHooks : uses
ContextProviders --> AuthHooks : manages

' Business Logic to API
AuthHooks --> AuthAPI : calls
DataHooks --> OrderAPI : calls
DataHooks --> AdminAPI : calls
DataHooks --> PayrollAPI : calls
RealtimeManager --> SupabaseClient : subscribes

' API to Services
AuthAPI --> AuthService : uses
AuthAPI --> EmailService : sends emails
AuthAPI --> RateLimitService : validates
OrderAPI --> CacheService : caches
AdminAPI --> StorageService : uploads
AdminAPI --> CacheService : invalidates
PayrollAPI --> PayrollPDFService : generates PDF

' API to Database
AuthAPI --> ServerQueries : queries
OrderAPI --> RPCFunctions : executes
AdminAPI --> ServerQueries : queries
PayrollAPI --> ServerQueries : queries

' Services to Database
ServerQueries --> SupabaseClient : uses
RPCFunctions --> SupabaseClient : executes

' Database Relationships
Orders "1" --> "*" OrderItems : contains
OrderItems "*" --> "1" MenuItems : references
MenuItems "*" --> "1" Categories : belongs to
Orders "*" --> "1" Customers : placed by
Attendance "*" --> "1" Employees : tracks
Payroll "*" --> "1" Employees : pays
Reviews "*" --> "1" Customers : written by
Reviews "*" --> "1" Orders : for
PromoCodes "*" --> "0..1" Customers : assigned to
Notifications "*" --> "1" Employees : sent to
Tables "*" --> "0..1" Employees : assigned to

' Cache Layer
CacheService --> SupabaseClient : fetches from

note right of AuthService
  JWT Token Management
  HTTP-only Cookies
  Role-based Permissions
end note

note right of RealtimeManager
  Deduplicates subscriptions
  Manages WebSocket channels
  Handles reconnection
end note

note right of CacheService
  Redis (Upstash)
  TTL: 30min - 1hr
  ISR integration
end note

note bottom of RPCFunctions
  Complex operations:
  - Order creation with validation
  - Employee setup with roles
  - Promo code application
  - Payroll calculations
end note

@enduml
