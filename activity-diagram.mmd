%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#E3F2FD',
    'primaryTextColor': '#0D47A1',
    'lineColor': '#37474F',
    'fontSize': '11px'
  }
}}%%

flowchart TD
    %% ==========================================
    %% START
    %% ==========================================
    START((🟢 Start))

    %% ==========================================
    %% PHASE 1: CUSTOMER ORDERING
    %% ==========================================
    subgraph PHASE1["📱 PHASE 1: Customer Ordering"]
        direction TB
        A1[👤 Visit Website]
        A2[📋 Browse Menu]
        A3[🛒 Add to Cart]
        A4{Apply Promo?}
        A5[🏷️ Enter Code]
        A6[📝 Review Cart]
        A7{Order Type?}
        A8[📍 Enter Address]
        A9[⏰ Select Time]
        A10[🍽️ Waiter Assigns Table]
        A11{Payment Method?}
        A12[💵 Cash Later]
        A13[💳 Process Card]
        A14{Payment OK?}
        A15[❌ Retry]
    end

    %% ==========================================
    %% PHASE 2: ORDER PROCESSING
    %% ==========================================
    subgraph PHASE2["💻 PHASE 2: System Processing"]
        direction TB
        B1[📧 Generate Order Number]
        B2[✉️ Send Confirmation Email]
        B3[🔔 Send Push Notification]
        B4[📋 Manager Monitors]
        B5[🔊 Alert Kitchen]
    end

    %% ==========================================
    %% PHASE 3: KITCHEN
    %% ==========================================
    subgraph PHASE3["👨‍🍳 PHASE 3: Kitchen Preparation"]
        direction TB
        C1[📋 Receive Order Alert]
        C2[📦 Check Ingredients]
        C3{Available?}
        C4[🍳 Start Cooking]
        C5[📱 Update: PREPARING]
        C6[👤 Customer Tracks]
        C7[✅ Finish Cooking]
        C8[🍽️ Mark READY]
        C9[📋 Manager Handles Issue]
    end

    %% ==========================================
    %% PHASE 4: FULFILLMENT
    %% ==========================================
    subgraph PHASE4["📦 PHASE 4: Order Fulfillment"]
        direction TB
        D0{Delivery Type?}
        
        subgraph DELIVERY["🛵 Home Delivery"]
            D1[📍 Assign Rider]
            D2[✅ Rider Accepts]
            D3[📦 Pick Up Order]
            D4[📱 Update: ON THE WAY]
            D5[👤 Customer Tracks GPS]
            D6[🏠 Deliver Food]
            D7{Cash Payment?}
            D8[💵 Collect Cash]
            D9[✅ Mark DELIVERED]
        end

        subgraph WALKIN["🏪 Walk-in Pickup"]
            W1[📢 Call Order Number]
            W2[👤 Customer Shows Code]
            W3{Cash?}
            W4[💵 Accept Cash]
            W5[🧾 Print Receipt]
            W6[📦 Hand Over]
        end

        subgraph DINEIN["🍽️ Dine-in Service"]
            T1[🍽️ Waiter Serves Table]
            T2[👤 Customer Eats]
            T3[📝 Request Bill]
            T4[💳 Billing Calculates]
            T5[💵 Process Payment]
            T6[🧾 Print Receipt]
            T7[🍽️ Clear Table]
        end
    end

    %% ==========================================
    %% PHASE 5: POST-ORDER
    %% ==========================================
    subgraph PHASE5["⭐ PHASE 5: Post-Order"]
        direction TB
        E1[⭐ Calculate Points]
        E2[🏆 Award Loyalty Points]
        E3[📝 Customer Reviews]
        E4[📊 Update Analytics]
        E5[📋 Manager Reviews Reports]
        E6{Low Stock?}
        E7[⚠️ Create Restock Alert]
    end

    %% ==========================================
    %% PHASE 6: ADMIN
    %% ==========================================
    subgraph PHASE6["🔑 PHASE 6: Admin Activities"]
        direction TB
        F1[📊 View System Activity]
        F2[📝 Check Audit Logs]
        F3[👥 Manage Employees]
        F4[💰 Process Payroll]
        F5[💾 Backup Database]
    end

    %% ==========================================
    %% END
    %% ==========================================
    ENDNODE((🔴 End))

    %% ==========================================
    %% CONNECTIONS
    %% ==========================================
    
    START --> A1
    A1 --> A2 --> A3 --> A4
    A4 -->|Yes| A5 --> A6
    A4 -->|No| A6
    A6 --> A7
    A7 -->|Delivery| A8 --> A11
    A7 -->|Walk-in| A9 --> A11
    A7 -->|Dine-in| A10 --> A11
    A11 -->|Cash| A12 --> B1
    A11 -->|Card| A13 --> A14
    A14 -->|Yes| B1
    A14 -->|No| A15 --> ENDNODE

    B1 --> B2 --> B3 --> B4 --> B5 --> C1

    C1 --> C2 --> C3
    C3 -->|Yes| C4 --> C5 --> C6 --> C7 --> C8 --> D0
    C3 -->|No| C9 --> C4

    D0 -->|Delivery| D1
    D0 -->|Walk-in| W1
    D0 -->|Dine-in| T1

    D1 --> D2 --> D3 --> D4 --> D5 --> D6 --> D7
    D7 -->|Yes| D8 --> D9
    D7 -->|No| D9
    D9 --> E1

    W1 --> W2 --> W3
    W3 -->|Yes| W4 --> W5
    W3 -->|No| W5
    W5 --> W6 --> E1

    T1 --> T2 --> T3 --> T4 --> T5 --> T6 --> T7 --> E1

    E1 --> E2 --> E3 --> E4 --> E5 --> E6
    E6 -->|Yes| E7 --> F1
    E6 -->|No| F1

    F1 --> F2 --> F3 --> F4 --> F5 --> ENDNODE

    %% ==========================================
    %% STYLING
    %% ==========================================
    classDef startEnd fill:#4CAF50,stroke:#2E7D32,color:#fff
    classDef endNode fill:#F44336,stroke:#C62828,color:#fff
    classDef customer fill:#C8E6C9,stroke:#2E7D32
    classDef system fill:#BBDEFB,stroke:#1565C0
    classDef kitchen fill:#FFCCBC,stroke:#E64A19
    classDef delivery fill:#F8BBD9,stroke:#C2185B
    classDef admin fill:#FFCDD2,stroke:#C62828
    classDef decision fill:#FFF8E1,stroke:#FF8F00

    class START startEnd
    class ENDNODE endNode
    class A1,A2,A3,A5,A6,A8,A9,A10,A12 customer
    class B1,B2,B3,B4,B5 system
    class C1,C2,C4,C5,C6,C7,C8,C9 kitchen
    class D1,D2,D3,D4,D5,D6,D8,D9 delivery
    class F1,F2,F3,F4,F5 admin
    class A4,A7,A11,A14,C3,D0,D7,W3,E6 decision
