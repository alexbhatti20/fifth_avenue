# ===========================================
# ZOIRO BROAST HUB - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# 
# For Vercel deployment, add these in your Vercel project settings:
# Settings > Environment Variables

# ----- SUPABASE -----
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Legacy VITE_ prefixed (for backwards compatibility)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (for server-side admin operations only)
# WARNING: This bypasses Row Level Security - never expose to client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----- REDIS (UPSTASH) -----
# Get these from your Upstash console
# Used for rate limiting and caching
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ----- SECURITY -----
# Generate with: openssl rand -base64 64
# Used for JWT token signing
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters

# ----- BREVO (EMAIL SERVICE) -----
# Get from your Brevo account > SMTP & API
# Used for sending transactional emails
BREVO_API_KEY=your-brevo-api-key-here
SENDER_EMAIL=info@zoirobroast.me

# ----- APP CONFIG -----
# Production URL: https://zoirobroast.me
# Development URL: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://zoirobroast.me

# ----- ALLOWED ORIGINS (CORS) -----
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://zoirobroast.me,https://www.zoirobroast.me

# ----- VERCEL (Auto-populated on Vercel) -----
# These are automatically set by Vercel - don't add manually
# VERCEL_URL - The deployment URL
# VERCEL_ENV - 'production', 'preview', or 'development'
# VERCEL_GIT_COMMIT_SHA - Git commit SHA
# VERCEL_GIT_COMMIT_REF - Git branch name

# ----- OPTIONAL: ANALYTICS -----
# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ----- OPTIONAL: ERROR TRACKING -----
# Sentry DSN
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ===========================================
# VERCEL DEPLOYMENT CHECKLIST:
# ===========================================
# 1. Add all NEXT_PUBLIC_* variables
# 2. Add SUPABASE_SERVICE_ROLE_KEY (Production only)
# 3. Add JWT_SECRET
# 4. Add BREVO_API_KEY
# 5. Add UPSTASH_REDIS_REST_URL and TOKEN
# 6. Set NEXT_PUBLIC_APP_URL to https://zoirobroast.me
# ===========================================
