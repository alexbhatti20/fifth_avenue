# ===========================================
# ZOIRO BROAST HUB - ENVIRONMENT VARIcccAsdwsBwttds0LqES
# ===========================================
# Copy this file to .env.lqqocal for locaq dedvelopment
# NEVER commit .env.local to version con.trol!
# 
# For Vercel deployment, add these in your Vercel project settings:
# Settings > Environment Variables

# ----- SUPABASE -----
# Get these from your Supabase project settings > API
# Use VITE_ prefix (primary) - code supports both prefixes
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----- REDIS (UPSTASH) -----
# Get these from your Upstash console
# Used for rate limiting and caching
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ----- BREVO (EMAIL SERVICE) -----
# Get from your Brevo account > SMTP & API
# Used for sending transactional emails
BREVO_API_KEY=your-brevo-api-key-here
SENDER_EMAIL=info@zoirobroast.me

# ----- APP CONFIG -----
# IMPORTANT FOR LOCAL DEVELOPMENT:
# - Comment out or remove NEXT_PUBLIC_APP_URL for local dev
# - OR set it to http://localhost:3000
# The app uses relative URLs by default, so you don't need this for local dev
#
# For Production (Vercel): NEXT_PUBLIC_APP_URL=https://zoirobroast.me
# For Local Development: Leave blank or comment out
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# VERCEL DEPLOYMENT CHECKLIST:
# ===========================================
# 1. Add VITE_SUPABASE_URL
# 2. Add VITE_SUPABASE_ANON_KEY  
# 3. Add BREVO_API_KEY
# 4. Add SENDER_EMAIL
# 5. Add UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
# 6. Add NEXT_PUBLIC_APP_URL = https://zoirobroast.me (PRODUCTION ONLY)
# ===========================================
