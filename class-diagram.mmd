classDiagram
    direction TB

    %% ==========================================
    %% INTERFACES & ABSTRACT CLASSES
    %% ==========================================

    class ITrackable {
        <<interface>>
        +getStatus()*
        +updateStatus()*
        +getHistory()*
    }

    class INotifiable {
        <<interface>>
        +sendNotification()*
        +getNotificationPreferences()*
    }

    class IAuditable {
        <<interface>>
        +logAction()*
        +getAuditTrail()*
    }

    class Person {
        <<abstract>>
        +String id
        +String name
        +String email
        +String phone
        ---
        +getFullName()*
        +validateEmail()
        +formatPhone()
    }

    %% ==========================================
    %% PEOPLE ENTITIES
    %% ==========================================

    class Customer {
        +String address
        ---
        +Int loyaltyPoints
        +LoyaltyTier loyaltyTier
        +Int totalOrders
        +Date registrationDate
        ---
        +List~MenuItem~ favorites
        +List~Order~ orderHistory
        ---
        +placeOrder()
        +trackOrder()
        +earnPoints()
        +writeReview()
        +redeemPoints()
    }

    class Employee {
        +String employeeId
        +EmployeeRole role
        +EmployeeStatus status
        ---
        +Decimal salary
        +Decimal tipsEarned
        +Date hireDate
        +Int ordersTaken
        ---
        +Boolean is2FAEnabled
        +Map~String,Boolean~ permissions
        +DateTime lastLogin
        ---
        +login()
        +checkAttendance()
        +updateProfile()
        +clockIn()
        +clockOut()
    }

    %% Person is parent of Customer and Employee
    Person <|-- Customer : extends
    Person <|-- Employee : extends

    %% Interface implementations
    Customer ..|> INotifiable : implements
    Employee ..|> IAuditable : implements
    Order ..|> ITrackable : implements
    Order ..|> INotifiable : implements

    class EmployeeRole {
        <<enumeration>>
        ADMIN
        MANAGER
        WAITER
        KITCHEN_STAFF
        BILLING_STAFF
        DELIVERY_RIDER
        OTHER
    }

    class EmployeeStatus {
        <<enumeration>>
        ACTIVE
        INACTIVE
        BLOCKED
        PENDING
    }

    %% ==========================================
    %% EMPLOYEE SUBCLASSES (Inheritance)
    %% ==========================================

    class Admin {
        <<Employee Subtype>>
        +manageEmployees()
        +processPayroll()
        +viewAuditLogs()
        +backupDatabase()
        +configureLoyalty()
    }

    class Manager {
        <<Employee Subtype>>
        +viewReports()
        +manageMenu()
        +manageDeals()
        +manageInventory()
        +reviewFeedback()
    }

    class Waiter {
        <<Employee Subtype>>
        +viewTables()
        +takeOrder()
        +requestTableExchange()
        +viewTips()
        +serveDineIn()
    }

    class KitchenStaff {
        <<Employee Subtype>>
        +viewOrderQueue()
        +markPreparing()
        +markReady()
        +checkIngredients()
    }

    class BillingStaff {
        <<Employee Subtype>>
        +generateBill()
        +processPayment()
        +applyDiscount()
        +processRefund()
        +printReceipt()
    }

    class DeliveryRider {
        <<Employee Subtype>>
        +viewDeliveries()
        +acceptDelivery()
        +updateStatus()
        +markDelivered()
        +collectCash()
    }

    %% ==========================================
    %% MENU ENTITIES
    %% ==========================================

    class Category {
        +String id
        +String name
        +String description
        +Int displayOrder
        +String image
        ---
        +getItems()
    }

    class MenuItem {
        +String id
        +String name
        +String description
        +Decimal price
        +Int prepTime
        ---
        +Boolean isAvailable
        +Boolean isFeatured
        +Decimal rating
        +Int reviewCount
        ---
        +List~SizeVariant~ sizeVariants
        ---
        +checkAvailability()
        +updatePrice()
    }

    class SizeVariant {
        +String size
        +Decimal price
        +Boolean isAvailable
    }

    class Deal {
        +String id
        +String name
        +String description
        +Decimal originalPrice
        +Decimal discountedPrice
        +Decimal savings
        ---
        +List~MenuItem~ includedItems
        +Date validUntil
        ---
        +calculateSavings()
    }

    %% ==========================================
    %% ORDER ENTITIES
    %% ==========================================

    class Order {
        +String orderNumber
        +DateTime orderDate
        +OrderType orderType
        +OrderStatus status
        ---
        +Decimal subtotal
        +Decimal discount
        +Decimal deliveryFee
        +Decimal tax
        +Decimal total
        ---
        +PaymentMethod paymentMethod
        +String customerName
        +String customerPhone
        +String deliveryAddress
        ---
        +calculateTotal()
        +updateStatus()
        +cancelOrder()
    }

    class OrderItem {
        +String id
        +MenuItem menuItem
        +Int quantity
        +String size
        +Decimal unitPrice
        +String instructions
        +Decimal lineTotal
        ---
        +calculateLineTotal()
    }

    class OrderType {
        <<enumeration>>
        DELIVERY
        WALK_IN
        DINE_IN
    }

    class OrderStatus {
        <<enumeration>>
        PENDING
        CONFIRMED
        PREPARING
        READY
        DELIVERING
        DELIVERED
        CANCELLED
    }

    %% ==========================================
    %% ORDER SUBCLASSES (Inheritance)
    %% ==========================================

    class DeliveryOrder {
        <<Order Subtype>>
        +String deliveryAddress
        +String riderName
        +DateTime estimatedTime
        +Decimal deliveryFee
        ---
        +assignRider()
        +trackLocation()
    }

    class DineInOrder {
        <<Order Subtype>>
        +Int tableNumber
        +String waiterName
        +Int guestCount
        ---
        +assignTable()
        +requestBill()
    }

    class WalkInOrder {
        <<Order Subtype>>
        +DateTime pickupTime
        +String tokenNumber
        ---
        +notifyReady()
    }

    %% ==========================================
    %% PAYMENT SUBCLASSES (Inheritance)
    %% ==========================================

    class Payment {
        <<abstract>>
        +String transactionId
        +Decimal amount
        +DateTime timestamp
        +PaymentStatus status
        ---
        +process()*
        +refund()*
        +generateReceipt()
    }

    class CashPayment {
        <<Payment Subtype>>
        +Decimal amountReceived
        +Decimal changeGiven
        ---
        +calculateChange()
    }

    class CardPayment {
        <<Payment Subtype>>
        +String cardLast4
        +String cardType
        +String authCode
        ---
        +authorize()
        +capture()
    }

    class OnlinePayment {
        <<Payment Subtype>>
        +String gatewayId
        +String walletType
        +String redirectUrl
        ---
        +initiatePayment()
        +verifyCallback()
    }

    class PaymentStatus {
        <<enumeration>>
        PENDING
        PROCESSING
        COMPLETED
        FAILED
        REFUNDED
    }

    class Invoice {
        +String invoiceNumber
        +Order order
        +Decimal totalDue
        +PaymentMethod paymentMethod
        +InvoiceStatus status
        +DateTime paidDate
        ---
        +generatePDF()
        +processPayment()
    }

    class PaymentMethod {
        <<enumeration>>
        CASH
        CARD
        ONLINE
        WALLET
    }

    class InvoiceStatus {
        <<enumeration>>
        DRAFT
        PENDING
        PAID
        CANCELLED
        REFUNDED
    }

    %% ==========================================
    %% OPERATIONS ENTITIES
    %% ==========================================

    class RestaurantTable {
        +Int tableNumber
        +Int capacity
        +String floor
        +String section
        +TableStatus status
        ---
        +Order currentOrder
        +Employee assignedWaiter
        ---
        +assignWaiter()
        +updateStatus()
    }

    class TableStatus {
        <<enumeration>>
        AVAILABLE
        OCCUPIED
        RESERVED
        CLEANING
        OUT_OF_SERVICE
    }

    class InventoryItem {
        +String name
        +Int quantity
        +Int minStockLevel
        +String unit
        ---
        +String supplier
        +Decimal costPerUnit
        +Date lastRestocked
        +Boolean lowStockAlert
        ---
        +restock()
        +checkLevel()
    }

    class Attendance {
        +String id
        +Employee employee
        +Date date
        +DateTime checkIn
        +DateTime checkOut
        +Decimal hoursWorked
        +Decimal overtimeHours
        +AttendanceStatus status
        ---
        +calculateHours()
    }

    class AttendanceStatus {
        <<enumeration>>
        PRESENT
        ABSENT
        LATE
        HALF_DAY
        ON_LEAVE
    }

    class Payroll {
        +String id
        +Employee employee
        +Int month
        +Int year
        ---
        +Decimal baseSalary
        +Decimal tips
        +Decimal bonus
        +Decimal deductions
        +Decimal netAmount
        ---
        +Boolean isPaid
        +DateTime paidAt
        ---
        +calculate()
        +process()
    }

    %% ==========================================
    %% MARKETING ENTITIES
    %% ==========================================

    class SpecialOffer {
        +String id
        +String name
        +String description
        +DiscountType discountType
        +Decimal discountValue
        ---
        +Decimal minOrderAmount
        +Decimal maxDiscount
        +Date startDate
        +Date endDate
        ---
        +Boolean showBanner
        +Boolean sendPush
        ---
        +applyDiscount()
        +isValid()
    }

    class DiscountType {
        <<enumeration>>
        PERCENTAGE
        FIXED_AMOUNT
        BUY_X_GET_Y
        BUNDLE_PRICE
    }

    class LoyaltyTier {
        <<enumeration>>
        BRONZE : 0-500 points
        SILVER : 501-1500 points
        GOLD : 1501-3000 points
        PLATINUM : 3001+ points
    }

    class Review {
        +String id
        +Customer customer
        +Order order
        +Int rating
        +String comment
        +DateTime date
        +Boolean isVisible
        ---
        +approve()
        +respond()
    }

    class Notification {
        +String id
        +String recipient
        +NotificationType type
        +String title
        +String message
        +Boolean isRead
        +DateTime sentAt
        ---
        +markAsRead()
        +send()
    }

    class NotificationType {
        <<enumeration>>
        ORDER
        SYSTEM
        ALERT
        PROMO
        MESSAGE
    }

    %% ==========================================
    %% SECURITY ENTITIES
    %% ==========================================

    class AuditLog {
        +String id
        +DateTime timestamp
        +Employee user
        +String actionType
        +String entity
        +String beforeValue
        +String afterValue
        +String ipAddress
    }

    class Session {
        +String id
        +String token
        +String device
        +DateTime loginTime
        +DateTime lastActivity
        +Boolean is2FAVerified
    }

    %% ==========================================
    %% RELATIONSHIPS - Advanced UML
    %% ==========================================

    %% INHERITANCE (Generalization) - Employee Roles inherit from base
    Employee <|-- Admin : inherits
    Employee <|-- Manager : inherits
    Employee <|-- Waiter : inherits
    Employee <|-- KitchenStaff : inherits
    Employee <|-- BillingStaff : inherits
    Employee <|-- DeliveryRider : inherits

    %% INHERITANCE - Order Types
    Order <|-- DeliveryOrder : inherits
    Order <|-- DineInOrder : inherits
    Order <|-- WalkInOrder : inherits

    %% INHERITANCE - Payment Methods
    Payment <|-- CashPayment : inherits
    Payment <|-- CardPayment : inherits
    Payment <|-- OnlinePayment : inherits

    %% COMPOSITION (Strong - Part dies with whole) ◆────
    Order "1" *-- "1..*" OrderItem : contains
    Invoice "1" *-- "1" Order : for
    Category "1" *-- "1..*" MenuItem : contains
    MenuItem "1" *-- "0..*" SizeVariant : has variants
    Deal "1" *-- "2..*" MenuItem : bundles

    %% AGGREGATION (Weak - Part can exist independently) ◇────
    Customer "1" o-- "0..*" Order : places
    Customer "1" o-- "0..*" Review : writes
    Customer "1" o-- "0..*" MenuItem : favorites
    Employee "1" o-- "0..*" Attendance : records
    Employee "1" o-- "0..*" Payroll : receives
    RestaurantTable "1" o-- "0..1" Order : serves
    RestaurantTable "1" o-- "0..1" Employee : assigned waiter

    %% ASSOCIATION (Uses/References) ────
    Customer "1" --> "1" LoyaltyTier : has tier
    Employee "1" --> "1" EmployeeRole : has role
    Employee "1" --> "1" EmployeeStatus : has status
    Order "1" --> "1" OrderStatus : has status
    Order "1" --> "1" PaymentMethod : paid via
    Invoice "1" --> "1" InvoiceStatus : has status
    RestaurantTable "1" --> "1" TableStatus : has status
    Attendance "1" --> "1" AttendanceStatus : has status
    SpecialOffer "1" --> "1" DiscountType : discount type

    %% DEPENDENCY (Uses temporarily) ..>
    Order ..> Invoice : generates
    OrderItem ..> MenuItem : references
    Review ..> Order : about
    Notification ..> Customer : sent to
    AuditLog ..> Employee : performed by

    %% MANY-TO-MANY ASSOCIATIONS
    SpecialOffer "*" -- "*" MenuItem : applies to
    SpecialOffer "*" -- "*" Deal : applies to
    MenuItem "*" -- "*" InventoryItem : uses ingredients

    %% SESSION ASSOCIATIONS
    Session "*" --> "1" Customer : customer session
    Session "*" --> "1" Employee : employee session

    %% ==========================================
    %% UML RELATIONSHIP LEGEND
    %% ==========================================
    %% 
    %% SYMBOL | MEANING | EXAMPLE
    %% -------|---------|--------
    %% <|--   | Inheritance (extends) | Employee <|-- Admin
    %% *--    | Composition (owns, part dies) | Order *-- OrderItem
    %% o--    | Aggregation (has, part survives) | Customer o-- Order
    %% -->    | Association (uses) | Order --> PaymentMethod
    %% ..>    | Dependency (temporary use) | Order ..> Invoice
    %% ..|>   | Realization (implements) | Customer ..|> INotifiable
    %% --     | Link (many-to-many) | MenuItem -- InventoryItem
    %%
    %% MULTIPLICITY:
    %% 1      = Exactly one
    %% 0..1   = Zero or one
    %% *      = Zero or many
    %% 1..*   = One or many
    %% 
    %% STEREOTYPES:
    %% <<interface>>    = Interface (all methods abstract)
    %% <<abstract>>     = Abstract class (some methods abstract)
    %% <<enumeration>>  = Enum type
    %% <<Subtype>>      = Concrete subclass
    %%
