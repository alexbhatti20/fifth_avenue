@startuml Zoiro Broast Hub - Class Diagram
title ZOIRO BROAST HUB\nBusiness Entities & Relationships\n(All System Objects)

' ========================================
' COMPACT VERTICAL LAYOUT FOR MS WORD
' ========================================
top to bottom direction
scale 0.55
skinparam backgroundColor #FAFAFA
skinparam linetype ortho

skinparam class {
    BackgroundColor #FFFFFF
    BorderColor #37474F
    HeaderBackgroundColor #E3F2FD
    FontSize 9
    AttributeFontSize 8
}

skinparam package {
    BackgroundColor #F5F5F5
    BorderColor #9E9E9E
    FontSize 10
}

' ========================================
' INTERFACES
' ========================================

interface ITrackable <<interface>> #E0E0E0 {
    getCreatedAt()
    getUpdatedAt()
    getCreatedBy()
}

interface INotifiable <<interface>> #E0E0E0 {
    sendNotification()
    getNotificationPrefs()
}

interface IAuditable <<interface>> #E0E0E0 {
    logChange()
    getHistory()
}

' ========================================
' PEOPLE - Users of the System
' ========================================

package "PEOPLE" #E8F5E9 {
    
    abstract class Person <<abstract>> #DCEDC8 {
        {abstract} id
        {abstract} name
        {abstract} email
        {abstract} phone
        --
        {abstract} getFullName()
        {abstract} validateEmail()
    }
    
    class Customer #C8E6C9 {
        Name
        Email / Phone
        Address
        --
        Loyalty Points
        Loyalty Tier
        Total Orders
        --
        Favorites List
        Order History
        --
        +placeOrder()
        +addToFavorites()
        +earnPoints()
    }
    
    class Employee #B2DFDB {
        Employee ID
        Name / Email / Phone
        Role
        Status
        --
        Salary
        Tips Earned
        Hire Date
        --
        2FA Enabled
        Permissions
        Last Login
        --
        +clockIn()
        +clockOut()
        +verify2FA()
    }
    
    class Admin #A5D6A7 {
        +manageEmployees()
        +viewAuditLogs()
        +configureSystem()
    }
    
    class Manager #80CBC4 {
        +approvePayroll()
        +manageInventory()
        +viewReports()
    }
    
    class Waiter #B2EBF2 {
        +takeOrder()
        +manageTable()
        +processBilling()
    }
    
    class KitchenStaff #FFCC80 {
        +updateOrderStatus()
        +viewQueue()
        +markReady()
    }
    
    class BillingStaff #CE93D8 {
        +processPayment()
        +generateInvoice()
        +handleRefund()
    }
    
    class DeliveryRider #90CAF9 {
        +acceptDelivery()
        +updateLocation()
        +confirmDelivery()
    }
}

' ========================================
' MENU & PRODUCTS
' ========================================

package "MENU" #FFF3E0 {
    
    class Category #FFE0B2 {
        Name
        Description
        Display Order
        Image
    }
    
    class "Menu Item" as MenuItem #FFCC80 {
        Name
        Description
        Price
        --
        Prep Time
        Available?
        Featured?
        --
        Rating
        Reviews Count
        --
        Size Variants
    }
    
    class "Deal / Combo" as Deal #FFB74D {
        Name
        Original Price
        Discounted Price
        Savings
        --
        Included Items
        Valid Until
    }
}

' ========================================
' ORDERS
' ========================================

package "ORDERS" #E3F2FD {
    
    abstract class Order <<abstract>> #BBDEFB {
        Order Number
        Date / Time
        --
        Subtotal
        Discount
        Tax
        Total
        --
        Status:
        Pending > Confirmed >
        Preparing > Ready
        --
        {abstract} +calculateTotal()
        {abstract} +updateStatus()
    }
    
    class DeliveryOrder #81D4FA {
        Delivery Address
        Delivery Fee
        Rider
        --
        +assignRider()
        +trackDelivery()
    }
    
    class DineInOrder #4FC3F7 {
        Table Number
        Waiter
        --
        +assignTable()
        +splitBill()
    }
    
    class WalkInOrder #29B6F6 {
        Counter Number
        --
        +printReceipt()
    }
    
    class "Order Item" as OrderItem #90CAF9 {
        Menu Item
        Quantity
        Size
        Price
        Instructions
    }
    
    class Invoice #64B5F6 {
        Invoice Number
        Total Due
        Payment Method
        Status
        Paid Date
        --
        +generate()
        +print()
    }
    
    abstract class Payment <<abstract>> #42A5F5 {
        Amount
        Timestamp
        Status
        --
        {abstract} +process()
        {abstract} +refund()
    }
    
    class CashPayment #66BB6A {
        Received
        Change
        --
        +calculateChange()
    }
    
    class CardPayment #7E57C2 {
        Card Last 4
        Auth Code
        --
        +authorize()
        +capture()
    }
    
    class OnlinePayment #FFB74D {
        Gateway
        Transaction ID
        --
        +verifyPayment()
        +handleWebhook()
    }
}

' ========================================
' RESTAURANT OPERATIONS
' ========================================

package "OPERATIONS" #FBE9E7 {
    
    class "Restaurant Table" as RestTable #FFCCBC {
        Table Number
        Capacity
        Floor / Section
        --
        Status:
        Available
        Occupied
        Reserved
        Cleaning
        --
        Current Order
        Assigned Waiter
    }
    
    class "Inventory Item" as Inventory #FFAB91 {
        Item Name
        Quantity
        Min Stock Level
        Unit
        --
        Supplier
        Cost per Unit
        Last Restocked
        Low Stock Alert?
    }
    
    class Attendance #FF8A65 {
        Employee
        Date
        Check-in / out
        Hours Worked
        Overtime
        Status
    }
    
    class Payroll #FF7043 {
        Employee
        Month / Year
        --
        Base Salary
        Tips
        Bonus
        Deductions
        --
        Net Amount
        Paid Status
    }
}

' ========================================
' MARKETING & LOYALTY
' ========================================

package "MARKETING" #F3E5F5 {
    
    class "Special Offer" as Offer #E1BEE7 {
        Offer Name
        Discount Type
        Discount Value
        --
        Min Order
        Max Discount
        Valid Period
        --
        Show Banner?
        Send Push?
    }
    
    class "Loyalty Tiers" as Loyalty #CE93D8 {
        Bronze (0-500)
        Silver (501-1500)
        Gold (1501-3000)
        Platinum (3001+)
        --
        Points per Rs.100
        Birthday Bonus
        Free Delivery
    }
    
    class Review #BA68C8 {
        Customer
        Order
        Rating (1-5)
        Comment
        Date
    }
    
    class Notification #AB47BC {
        Recipient
        Type: Order
              Promo
              Alert
        Title / Message
        Read Status
    }
}

' ========================================
' SECURITY & AUDIT
' ========================================

package "SECURITY" #E8EAF6 {
    
    class "Audit Log" as Audit #C5CAE9 {
        Timestamp
        User
        Action Type
        Entity
        Before / After
        IP Address
    }
    
    class Session #9FA8DA {
        User
        Token
        Device
        Login Time
        2FA Verified?
    }
}

' ========================================
' RELATIONSHIPS - Advanced UML
' ========================================

' ---- INHERITANCE (Generalization) ----
Person <|-- Customer : extends
Person <|-- Employee : extends

Employee <|-- Admin : extends
Employee <|-- Manager : extends
Employee <|-- Waiter : extends
Employee <|-- KitchenStaff : extends
Employee <|-- BillingStaff : extends
Employee <|-- DeliveryRider : extends

Order <|-- DeliveryOrder : extends
Order <|-- DineInOrder : extends
Order <|-- WalkInOrder : extends

Payment <|-- CashPayment : extends
Payment <|-- CardPayment : extends
Payment <|-- OnlinePayment : extends

' ---- INTERFACE REALIZATION ----
Customer ..|> INotifiable : implements
Employee ..|> IAuditable : implements
Order ..|> ITrackable : implements
Order ..|> IAuditable : implements

' ---- COMPOSITION (strong ownership) ----
Order *-- "1..*" OrderItem : contains
Invoice *-- Payment : processes
Category *-- "1..*" MenuItem : owns

' ---- AGGREGATION (weak ownership) ----
Customer o-- "0..*" Order : places
Deal o-- "2..*" MenuItem : bundles
RestTable o-- "0..1" Order : serves

' ---- ASSOCIATION ----
Customer "1" -- "0..*" Review : writes
Customer -- Loyalty : earns points
DineInOrder -- RestTable : uses
DeliveryOrder -- DeliveryRider : assigned to
DineInOrder -- Waiter : served by
Notification -- Customer : notifies

' ---- DEPENDENCY ----
Employee ..> Attendance : records
Employee ..> Payroll : receives
Inventory ..> MenuItem : supplies
Offer ..> MenuItem : applies to
Offer ..> Deal : applies to

' ---- MANY-TO-MANY ----
Employee -- "0..*" RestTable : manages

' Security associations
Audit -- Employee : records
Session -- Customer
Session -- Employee

' ========================================
' LEGEND
' ========================================

legend bottom
  <b>ENTITY GROUPS</b>
  |= Package |= Contains |
  | People | Customer, Employee (Admin, Manager, Waiter, Kitchen, Billing, Rider) |
  | Menu | Categories, Items, Deals/Combos |
  | Orders | Order Types, Items, Invoices, Payments |
  | Operations | Tables, Inventory, Attendance, Payroll |
  | Marketing | Offers, Loyalty, Reviews, Notifications |
  | Security | Audit Logs, User Sessions |
  
  <b>UML RELATIONSHIP SYMBOLS</b>
  --|> = <b>Inheritance</b> (extends class)
  ..|> = <b>Realization</b> (implements interface)
  *-- = <b>Composition</b> (strong ownership, child dies with parent)
  o-- = <b>Aggregation</b> (weak ownership, child can exist alone)
  --> = <b>Association</b> (uses relationship)
  ..> = <b>Dependency</b> (depends on)
  
  <b>CARDINALITY</b>
  1 = One | 0..1 = Zero or One | 0..* = Zero or Many | 1..* = One or Many
endlegend

@enduml
