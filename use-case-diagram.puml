@startuml Zoiro Broast Hub - Use Case Diagram
title ZOIRO BROAST HUB - Use Case Diagram

' ========================================
' SQUARE LAYOUT WITH HORIZONTAL ACTORS
' ========================================
top to bottom direction
scale 0.7
skinparam backgroundColor #FAFAFA
skinparam linetype ortho

skinparam actor {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    FontSize 10
}

skinparam usecase {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 8
    BorderThickness 1
}

skinparam rectangle {
    BackgroundColor #FFFDE7
    BorderColor #F57C00
    BorderThickness 2
    RoundCorner 10
}

' ========================================
' ALL ACTORS IN HORIZONTAL ROW (TOP)
' ========================================

actor "Customer" as C #C8E6C9
actor "Waiter" as W #FFE0B2
actor "Kitchen" as K #FFCCBC
actor "Billing" as B #D1C4E9
actor "Rider" as R #F8BBD9
actor "Manager" as M #B2DFDB
actor "Admin" as A #FFCDD2

' ========================================
' SQUARE SYSTEM BOX
' ========================================

rectangle "ZOIRO BROAST HUB" as System {

    ' ROW 1: Customer Actions
    (Browse Menu) as UC1
    (Add to Cart) as UC2
    (Place Order) as UC3
    (Track Order) as UC4
    (Pay) as UC5
    (Earn Points) as UC6
    (Write Review) as UC7

    ' ROW 2: Account & Waiter
    (Register) as UC9
    (Login/OTP) as UC10
    (2FA) as UC12
    (View Tables) as UC14
    (Take Order) as UC15
    (Table Exchange) as UC16
    (View Tips) as UC17

    ' ROW 3: Kitchen & Billing
    (Order Queue) as UC18
    (Mark Preparing) as UC19
    (Mark Ready) as UC20
    (Check Stock) as UC21
    (Generate Bill) as UC22
    (Process Payment) as UC23
    (Print Receipt) as UC26

    ' ROW 4: Delivery & Management
    (View Deliveries) as UC27
    (Accept Delivery) as UC28
    (Update Status) as UC29
    (Mark Delivered) as UC30
    (Sales Reports) as UC31
    (Manage Menu) as UC33
    (Inventory) as UC35

    ' ROW 5: Admin Functions
    (Add Employee) as UC37
    (Manage Roles) as UC38
    (Payroll) as UC40
    (Audit Logs) as UC41
    (DB Backup) as UC42
    (Loyalty) as UC43
    (Attendance) as UC45
}

' ========================================
' CONNECTIONS - All Actors to Use Cases
' ========================================

' Customer (Ordering & Account)
C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC5
C --> UC6
C --> UC7
C --> UC9
C --> UC10
C --> UC12

' Waiter (Tables & Service)
W --> UC10
W --> UC14
W --> UC15
W --> UC16
W --> UC17
W --> UC45

' Kitchen (Food Prep)
K --> UC10
K --> UC18
K --> UC19
K --> UC20
K --> UC21
K --> UC45

' Billing (Payments)
B --> UC10
B --> UC22
B --> UC23
B --> UC26
B --> UC45

' Rider (Delivery)
R --> UC10
R --> UC27
R --> UC28
R --> UC29
R --> UC30
R --> UC45

' Manager (Operations)
M --> UC10
M --> UC31
M --> UC33
M --> UC35
M --> UC42
M --> UC45

' Admin (Full System)
A --> UC10
A --> UC31
A --> UC33
A --> UC35
A --> UC37
A --> UC38
A --> UC40
A --> UC41
A --> UC42
A --> UC43

' ========================================
' LEGEND
' ========================================

legend right
  |= Actor |= Responsibilities |
  | Customer | Order, pay, track, review |
  | Waiter | Tables, dine-in |
  | Kitchen | Cook, mark ready |
  | Billing | Payments, receipts |
  | Rider | Deliveries |
  | Manager | Reports, inventory |
  | Admin | Employees, system |
endlegend

@enduml
