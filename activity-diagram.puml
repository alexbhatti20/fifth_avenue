@startuml Zoiro Broast Hub - Activity Diagram
title ZOIRO BROAST HUB\nComplete Order Flow Process\n(All 7 Roles)

' ========================================
' COMPACT VERTICAL LAYOUT FOR MS WORD
' ========================================
scale 0.6
skinparam backgroundColor #FAFAFA
skinparam ActivityFontSize 9
skinparam PartitionFontSize 10
skinparam ArrowFontSize 8

skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 9
    DiamondBackgroundColor #FFF8E1
    DiamondBorderColor #FF8F00
}

skinparam swimlane {
    BorderColor #37474F
    TitleFontSize 10
}

' ========================================
' SWIMLANES - All 7 Roles + System
' ========================================

|#C8E6C9| Customer |
|#FFE0B2| Waiter |
|#FFCCBC| Kitchen |
|#D1C4E9| Billing |
|#F8BBD9| Rider |
|#B2DFDB| Manager |
|#FFCDD2| Admin |
|#BBDEFB| System |

' ========================================
' PHASE 1: CUSTOMER ORDERING
' ========================================

|Customer|
start
:Visit Website;
:Browse Menu Categories;
:View Item Details;
:Add to Cart;

if (Apply Promo?) then (yes)
    :Enter Code;
else (no)
endif

:Review Cart;
:Select Order Type;

switch (Order Type?)
case (Delivery)
    :Enter Address & Phone;
case (Walk-in)
    :Select Pickup Time;
case (Dine-in)
    |Waiter|
    :Check Available Tables;
    :Assign Table;
    :Take Dine-in Order;
    |Customer|
endswitch

:Choose Payment Method;

switch (Payment?)
case (Cash)
    :Cash on Delivery/Pickup;
case (Card)
    |System|
    :Process Card Payment;
    if (Success?) then (yes)
        :Payment Confirmed;
    else (no)
        |Customer|
        :Payment Failed - Retry;
        stop
    endif
    |Customer|
case (Online)
    |System|
    :Process Online Payment;
    |Customer|
endswitch

' ========================================
' PHASE 2: ORDER PROCESSING
' ========================================

|System|
:Generate Order Number;
:Send Email Confirmation;
:Send Push Notification;
:Alert Kitchen Staff;

|Manager|
:Monitor New Order;
:Check Real-time Dashboard;

' ========================================
' PHASE 3: KITCHEN PREPARATION
' ========================================

|Kitchen|
:Receive Order Alert;
:View Order Details;
:Check Ingredient Stock;

if (All Available?) then (yes)
    :Start Cooking;
    
    |System|
    :Update Status: PREPARING;
    :Notify Customer;
    
    |Customer|
    :Track Order Status Live;
    
    |Kitchen|
    :Complete Cooking;
    :Quality Check;
    :Mark as READY;
    
    |System|
    :Update Status: READY;
    :Send Ready Notification;
else (no)
    |Manager|
    :Handle Unavailable Item;
    :Contact Customer;
    :Offer Alternative;
    |Kitchen|
endif

' ========================================
' PHASE 4: DELIVERY / PICKUP / DINE-IN
' ========================================

|System|

switch (Delivery Method?)
case (Home Delivery)
    :Find Nearest Rider;
    :Assign to Rider;
    
    |Rider|
    :Receive Delivery Alert;
    :Accept Delivery;
    :Go to Restaurant;
    :Pick Up Order;
    
    |System|
    :Update: ON THE WAY;
    :Notify Customer;
    
    |Customer|
    :Track Rider on Map;
    
    |Rider|
    :Navigate to Address;
    :Arrive at Location;
    :Deliver Food;
    
    if (Cash Payment?) then (yes)
        :Collect Cash;
        :Give Change;
    else (no)
    endif
    
    :Mark as DELIVERED;
    :Update Attendance;
    
    |System|
    :Confirm Delivery;
    
case (Walk-in Pickup)
    |Billing|
    :Announce Order Number;
    
    |Customer|
    :Come to Counter;
    :Show Order Confirmation;
    
    |Billing|
    if (Cash Payment?) then (yes)
        :Accept Cash;
        :Process Payment;
    else (no)
    endif
    :Generate Invoice;
    :Print Receipt;
    :Hand Over Order;
    
case (Dine-in Service)
    |Waiter|
    :Get Order from Kitchen;
    :Serve at Table;
    
    |Customer|
    :Enjoy Meal;
    :Finish Eating;
    :Request Bill;
    
    |Waiter|
    :Request Bill Generation;
    
    |Billing|
    :Calculate Total + Tax;
    :Generate Final Bill;
    
    |Waiter|
    :Present Bill to Customer;
    
    |Customer|
    :Pay Bill;
    
    |Billing|
    :Process Payment;
    :Print Receipt;
    
    |Waiter|
    :Clear Table;
    :Update Table Status;
    :Record Tips;
    
endswitch

' ========================================
' PHASE 5: POST-ORDER ACTIVITIES
' ========================================

|System|
:Calculate Loyalty Points;
:Award Points to Customer;
:Update Customer Profile;

|Customer|
:Receive Points Notification;
:Check Loyalty Balance;
:Write Review (Optional);

|System|
:Save Review;
:Update Item Ratings;
:Generate Order Analytics;

|Manager|
:View Sales Reports;
:Check Daily Revenue;
:Monitor Inventory Levels;

if (Low Stock Alert?) then (yes)
    :Create Restock Request;
    
    |Admin|
    :Approve Restock Order;
else (no)
endif

|Manager|
:Review Customer Feedback;
:Plan Promotions;

' ========================================
' PHASE 6: ADMIN ACTIVITIES
' ========================================

|Admin|
:View All System Activity;
:Check Audit Logs;
:Manage Employee Accounts;
:Process Monthly Payroll;

|System|
:Generate Payroll Report;

|Admin|
:Approve Payments;
:Backup Database;

stop

' ========================================
' LEGEND - ALL ROLES EXPLAINED
' ========================================

legend bottom
  <b>ALL ROLES IN ORDER FLOW</b>
  |= Role |= Color |= Key Activities |
  | Customer | Green | Browse, order, pay, track, review |
  | Waiter | Orange | Assign tables, take orders, serve, tips |
  | Kitchen | Peach | View queue, cook, mark ready |
  | Billing | Purple | Process payments, invoices, receipts |
  | Rider | Pink | Accept delivery, pickup, deliver, collect cash |
  | Manager | Teal | Reports, inventory, promotions, oversight |
  | Admin | Red | Employees, payroll, audit, backup |
  | System | Blue | Auto-processing, notifications, tracking |
endlegend

@enduml
